# Public app URL used for canonical URLs, redirects, and callback pages.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project URL and browser-safe public keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Legacy fallback if you are not using the publishable key above.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Server-only Supabase role key for admin mutations and protected storage access.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional Supabase storage bucket names used for invoices and visa uploads.
SUPABASE_INVOICES_BUCKET=invoice-pdfs
SUPABASE_VISA_DOCUMENTS_BUCKET=visa-documents
SUPABASE_LIVE_CHAT_ATTACHMENTS_BUCKET=live-chat-attachments

# Stripe card payments.
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key

# Local-only payment simulator for development when Stripe is not configured.
# Keep false outside deliberate local functional testing.
ENABLE_DEV_CHECKOUT=false

# Paystack Nigerian payments.
PAYSTACK_SECRET_KEY=sk_test_your_key
PAYSTACK_PUBLIC_KEY=pk_test_your_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_key

# Flutterwave hosted checkout fallback keys. Admin Settings can store these encrypted instead.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_secret_hash

# Korapay checkout fallback keys. Admin Settings can store these encrypted instead.
KORAPAY_SECRET_KEY=sk_test_your_key
KORAPAY_PUBLIC_KEY=pk_test_your_key

# Duffel live flight search.
DUFFEL_ACCESS_TOKEN=duffel_test_your_token

# Transactional email delivery.
RESEND_API_KEY=re_your_key
EMAIL_FROM=bookings@aurevia.travel
EMAIL_FROM_NAME=Aurevia Travel

# Live exchange rates.
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# One-time bootstrap setup tool. Disable this after your first super admin is created.
SETUP_SECRET_KEY=choose_a_long_random_string_here
SETUP_ENABLED=false

# Company details used on invoices, PDFs, and receipts.
AUREVIA_COMPANY_NAME=Aurevia Travel
AUREVIA_COMPANY_EMAIL=billing@aurevia.example
AUREVIA_COMPANY_ADDRESS=Vienna, Austria
AUREVIA_COMPANY_VAT_ID=ATU-REVIEW-REQUIRED

# Admin integration encryption key for stored secrets.
ADMIN_SECRET_ENCRYPTION_KEY=replace_with_a_32_character_secret
