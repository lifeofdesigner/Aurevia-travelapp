# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public browser configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy fallback. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase access
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Korapay
KORAPAY_SECRET_KEY=
KORAPAY_PUBLIC_KEY=

# Email delivery
RESEND_API_KEY=
EMAIL_FROM="Aurevia Travel <bookings@aurevia.example>"

# Invoice/company placeholders. Replace before production launch.
AUREVIA_COMPANY_NAME="Aurevia Travel"
AUREVIA_COMPANY_EMAIL="billing@aurevia.example"
AUREVIA_COMPANY_ADDRESS="Vienna, Austria"
AUREVIA_COMPANY_VAT_ID="ATU-REVIEW-REQUIRED"

# Private storage buckets
SUPABASE_INVOICES_BUCKET=invoice-pdfs
SUPABASE_VISA_DOCUMENTS_BUCKET=visa-documents
SUPABASE_LIVE_CHAT_ATTACHMENTS_BUCKET=live-chat-attachments
